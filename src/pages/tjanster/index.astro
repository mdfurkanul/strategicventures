---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';
import JourneyDiagram from '../../components/JourneyDiagram.astro';
import TestimonialSlider from '../../components/TestimonialSlider.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getUI } from '../../data/i18n';
import { services } from '../../data/services';

const locale = 'sv' as const;
const t = getUI(locale);
const path = '/tjanster';
---
<BaseLayout locale={locale} path={path} title={`${t.services.heroTitle} | Strategic Ventures`} description={t.services.heroSubtitle}>
  <Breadcrumbs items={[{ label: t.nav.home, href: '/' }, { label: t.nav.services }]} />
  <PageHero eyebrow={t.nav.services} title={t.services.heroTitle} subtitle={t.services.heroSubtitle} />

  <!-- JOURNEY DIAGRAM -->
  <section class="bg-gradient-to-b from-navy-50/40 to-white border-b border-navy-100">
    <div class="mx-auto max-w-7xl px-5 py-16 sm:px-8 sm:py-20">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <p data-reveal class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-navy ring-1 ring-navy-100">
          <span class="h-1.5 w-1.5 rounded-full bg-navy"></span>
          Från idé till hållbar tillväxt
        </p>
        <h2 data-reveal class="mt-5 font-serif text-3xl font-semibold text-navy sm:text-4xl">Vår resa i sju steg</h2>
        <p data-reveal class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-ink/70 sm:text-lg">
          Vi följer med genom hela resan — från den första idén och strategin till innovation, finansiering, marknadsetablering och långsiktig kunskapsutveckling.
        </p>
      </div>
      <div data-reveal class="mt-12 overflow-x-auto">
        <JourneyDiagram locale={locale} />
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
      <div class="mb-10 max-w-2xl">
        <p data-reveal class="text-xs font-semibold uppercase tracking-wider text-sky-600">{t.nav.services}</p>
        <h2 data-reveal class="mt-2 font-serif text-3xl font-semibold text-navy sm:text-4xl">Utforska alla tjänsteområden</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service, i) => (
          <div data-reveal data-reveal-delay={(i % 3) * 100}>
            <ServiceCard service={service} locale={locale} />
          </div>
        ))}
      </div>
    </div>
  </section>
  <!-- CUSTOMER REVIEWS -->
  <section class="bg-gradient-to-b from-white to-navy-50/40 border-t border-navy-100">
    <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8 sm:py-24">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <p data-reveal class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-navy ring-1 ring-navy-100">
          <span class="h-1.5 w-1.5 rounded-full bg-navy"></span>
          Kundröster · 5 av 5
        </p>
        <h2 data-reveal class="mt-5 font-serif text-3xl font-semibold text-navy sm:text-4xl">Våra kunder berättar</h2>
        <p data-reveal class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-ink/70 sm:text-lg">
          Från start-ups till etablerade tillverkare, från forskningsinstitut till offentlig sektor — här är vad våra partners säger om arbetet med oss.
        </p>
      </div>
      <div data-reveal class="mt-10">
        <TestimonialSlider locale={locale} />
      </div>
    </div>
  </section>

  <CTASection locale={locale} />
</BaseLayout>
