---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getUI } from '../data/i18n';
const locale = 'sv' as const;
const t = getUI(locale);
const path = '/branscher';
const icons = ['wheat','leaf','strategy','sparkles','cap','target','shield','globe','handshake','lightbulb','strategy','leaf','leaf','leaf','globe'];
---
<BaseLayout locale={locale} path={path} title={`${t.industries.title} | Strategic Ventures`} description={t.industries.subtitle}>
  <Breadcrumbs items={[{ label: t.nav.home, href: '/' }, { label: t.nav.industries }]} />
  <PageHero eyebrow={t.nav.industries} title={t.industries.title} subtitle={t.industries.subtitle} />
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {t.industries.list.map((ind, i) => {
          const colors = ['navy','sky','growth'];
          const color = colors[i % 3];
          const iconBg = color === 'navy' ? 'bg-navy-50 text-navy group-hover:bg-navy group-hover:text-white' : color === 'sky' ? 'bg-sky-50 text-sky group-hover:bg-sky group-hover:text-white' : 'bg-growth-50 text-growth group-hover:bg-growth group-hover:text-white';
          return (
            <div data-reveal data-reveal-delay={(i % 3) * 70} class="group flex items-center gap-4 rounded-2xl border border-navy-100 bg-white p-5 transition hover:-translate-y-0.5 hover:border-navy-200 hover:shadow-md">
              <span class={`inline-flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl transition duration-300 ${iconBg}`}>
                <svg viewBox="0 0 24 24" class="h-5 w-5 transition group-hover:scale-110" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
              </span>
              <span class="font-serif text-base font-medium text-navy">{ind}</span>
            </div>
          );
        })}
      </div>
    </div>
  </section>
  <CTASection locale={locale} />
</BaseLayout>
