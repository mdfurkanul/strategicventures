---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';
import { getUI } from '../data/i18n';
import { goals } from '../data/sdg';
const locale = 'sv' as const;
const t = getUI(locale);
const path = '/hallbarhet';
---
<BaseLayout locale={locale} path={path} title={`${t.sustainability.heroTitle} | Strategic Ventures`} description={t.sustainability.subtitle}>
  <Breadcrumbs items={[{ label: t.nav.home, href: '/' }, { label: t.nav.sustainability }]} />
  <PageHero eyebrow={t.nav.sustainability} title={t.sustainability.heroTitle} subtitle={t.sustainability.subtitle} />

  <!-- Philosophy + commitment -->
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <div data-reveal>
          <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-growth text-white">
            <Icon name="leaf" class="h-7 w-7" />
          </div>
          <h2 class="font-serif text-3xl font-semibold text-navy">{t.sustainability.philosophyTitle}</h2>
          <p class="mt-4 leading-relaxed text-ink/75">{t.sustainability.philosophy}</p>
        </div>
        <div data-reveal data-reveal-delay="120" class="rounded-3xl bg-navy-50/60 p-8 ring-1 ring-navy-100">
          <h3 class="font-serif text-xl font-semibold text-navy">{t.sustainability.commitmentTitle}</h3>
          <ul class="mt-4 space-y-3">
            {t.sustainability.commitmentList.map((item, i) => (
              <li data-reveal data-reveal-delay={i * 60} class="flex items-start gap-3 text-sm leading-relaxed text-ink/80">
                <Icon name="check" class="mt-0.5 h-4 w-4 flex-shrink-0 text-growth" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SUSTAINABILITY GOALS — connected timeline path -->
  <section class="bg-gradient-to-b from-growth-50/40 to-white border-y border-navy-100">
    <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <p data-reveal class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-growth-700 ring-1 ring-growth-100">
          <span class="h-1.5 w-1.5 rounded-full bg-growth"></span>
          Våra mål · FN Agenda 2030
        </p>
        <Icon name="globe" class="mx-auto mt-6 h-10 w-10 text-growth" />
        <h2 data-reveal class="mt-3 font-serif text-3xl font-semibold text-navy sm:text-4xl">{t.sustainability.sdgTitle}</h2>
        <p data-reveal class="mt-4 text-ink/75">{t.sustainability.sdg}</p>
      </div>

      <!-- TIMELINE -->
      <div class="mx-auto mt-16 max-w-3xl">
        <!-- Start marker -->
        <div data-reveal class="mb-2 flex items-center gap-3 pl-[14px]">
          <span class="h-2 w-2 rounded-full bg-navy-300"></span>
          <span class="font-mono text-[10px] font-medium uppercase tracking-[0.18em] text-ink/50">Start · 12 steg</span>
        </div>

        <ol class="relative">
          <!-- continuous gradient spine -->
          <span aria-hidden="true" class="pointer-events-none absolute left-[27px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-navy-300 via-sky-300 to-growth-400"></span>

          {goals.map((goal, i) => {
            const accent = goal.color === 'navy'
              ? { dot: 'bg-navy', text: 'text-navy', border: 'border-navy', fillBg: 'group-hover:bg-navy' }
              : goal.color === 'sky'
              ? { dot: 'bg-sky', text: 'text-sky-600', border: 'border-sky', fillBg: 'group-hover:bg-sky' }
              : { dot: 'bg-growth', text: 'text-growth-600', border: 'border-growth', fillBg: 'group-hover:bg-growth' };
            return (
              <li
                data-reveal
                data-reveal-delay={(i % 3) * 80}
                class="group relative grid grid-cols-[56px_1fr] gap-4 pb-6 sm:gap-6 sm:pb-8"
              >
                <!-- icon node on the spine -->
                <div class="relative">
                  <div class={`relative z-10 flex h-14 w-14 items-center justify-center rounded-full border-2 ${accent.border} bg-white ${accent.text} shadow-sm ring-4 ring-white transition duration-300 ${accent.fillBg} group-hover:text-white`}>
                    <Icon name={goal.icon as any} class="h-6 w-6" />
                  </div>
                  <!-- small number badge -->
                  <span class={`absolute -right-1 -top-1 z-20 inline-flex h-5 w-5 items-center justify-center rounded-full ${accent.dot} font-mono text-[9px] font-bold text-white shadow-sm`}>
                    {String(goal.num).padStart(2, '0')}
                  </span>
                </div>

                <!-- card / stop on the path -->
                <div class="rounded-2xl border border-navy-100 bg-white p-5 transition duration-300 group-hover:-translate-y-0.5 group-hover:border-navy-200 group-hover:shadow-lg sm:p-6">
                  <div class="flex items-center gap-2">
                    <span class={`inline-block h-1.5 w-1.5 rounded-full ${accent.dot}`}></span>
                    <span class="font-mono text-[10px] font-medium uppercase tracking-[0.16em] text-ink/50">FN Mål {goal.unNum}</span>
                  </div>
                  <h3 class="mt-2 font-serif text-lg font-semibold leading-snug text-navy">{goal.title[locale]}</h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-ink/70">{goal.desc[locale]}</p>
                </div>
              </li>
            );
          })}

          <!-- End / destination marker -->
          <li data-reveal class="relative grid grid-cols-[56px_1fr] gap-4 sm:gap-6">
            <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-navy via-sky to-growth text-white shadow-md ring-4 ring-white">
              <Icon name="check" class="h-6 w-6" />
            </div>
            <div class="flex items-center">
              <p class="font-serif text-lg italic text-navy/70">Hållbar värdeskapande — tillsammans.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- Action — light card instead of heavy navy block -->
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-5 py-12 sm:px-8">
      <div data-reveal class="relative overflow-hidden rounded-3xl border border-navy-100 bg-gradient-to-br from-navy-50/60 via-white to-growth-50/40 px-6 py-16 sm:px-16">
        <div class="pointer-events-none absolute inset-0" aria-hidden="true">
          <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-sky-100/60 blur-3xl"></div>
          <div class="absolute -bottom-24 -left-20 h-72 w-72 rounded-full bg-growth-100/60 blur-3xl"></div>
        </div>
        <div class="relative mx-auto max-w-3xl text-center">
          <div class="mb-6 flex items-center justify-center gap-2" aria-hidden="true">
            <span class="h-2 w-2 rounded-full bg-navy"></span>
            <span class="h-2 w-2 rounded-full bg-sky"></span>
            <span class="h-2 w-2 rounded-full bg-growth"></span>
          </div>
          <Icon name="target" class="mx-auto h-10 w-10 text-navy" />
          <h2 class="mt-4 font-serif text-3xl font-semibold text-navy sm:text-4xl">{t.sustainability.actionTitle}</h2>
          <p class="mx-auto mt-5 max-w-2xl leading-relaxed text-ink/75">{t.sustainability.action}</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection locale={locale} />
</BaseLayout>
