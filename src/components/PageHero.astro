---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  variant?: 'light' | 'tint';
}
const { eyebrow, title, subtitle, align = 'center', variant = 'tint' } = Astro.props;
---
<section class={`relative overflow-hidden ${variant === 'tint' ? 'bg-gradient-to-b from-navy-50/70 to-white' : 'bg-white'} border-b border-navy-100`}>
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -right-32 -top-24 h-96 w-96 rounded-full bg-sky-100/50 blur-3xl"></div>
    <div class="absolute -left-32 top-0 h-80 w-80 rounded-full bg-growth-100/40 blur-3xl"></div>
  </div>
  <div class={`relative mx-auto max-w-4xl px-5 py-20 sm:px-8 sm:py-24 ${align === 'center' ? 'text-center' : 'text-left'}`}>
    {eyebrow && (
      <p class={`text-xs font-semibold uppercase tracking-wider text-sky-600 ${align === 'center' ? '' : ''}`}>{eyebrow}</p>
    )}
    <h1 class="mt-3 font-serif text-4xl font-bold leading-[1.1] tracking-tight text-navy sm:text-5xl md:text-[3.4rem]">
      {title}
    </h1>
    {subtitle && (
      <p class={`mt-5 text-lg leading-relaxed text-ink/75 ${align === 'center' ? 'mx-auto max-w-2xl' : 'max-w-2xl'}`}>{subtitle}</p>
    )}
  </div>
</section>
