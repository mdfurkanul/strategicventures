---
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import Icon from './Icon.astro';
import { getUI } from '../data/i18n';
import type { Locale } from '../data/site';

export interface Props { locale: Locale; path: string; }
const { locale, path } = Astro.props;
const t = getUI(locale);
const prefix = locale === 'en' ? '/en' : '';

const links = [
  { href: `${prefix}${locale === 'en' ? '/services' : '/tjanster'}`, label: t.nav.services, key: 'services' },
  { href: `${prefix}${locale === 'en' ? '/about' : '/om-oss'}`, label: t.nav.about, key: 'about' },
  { href: `${prefix}${locale === 'en' ? '/industries' : '/branscher'}`, label: t.nav.industries, key: 'industries' },
  { href: `${prefix}${locale === 'en' ? '/why-us' : '/varfor-oss'}`, label: t.nav.why, key: 'why' },
  { href: `${prefix}${locale === 'en' ? '/sustainability' : '/hallbarhet'}`, label: t.nav.sustainability, key: 'sustainability' },
];

// normalise current path for active state
const current = Astro.url.pathname;
function isActive(href: string) {
  return current === href || (href !== `${prefix}/` && current.startsWith(href));
}
---
<header class="sticky top-0 z-50 border-b border-navy-100/60 bg-white/85 backdrop-blur">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between gap-4 px-5 sm:px-8">
    <Logo />

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class={`rounded-full px-3.5 py-2 text-sm font-medium transition ${
            isActive(l.href)
              ? 'bg-navy-50 text-navy'
              : 'text-ink/70 hover:bg-navy-50/60 hover:text-navy'
          }`}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <LanguageSwitcher locale={locale} path={path} />
      <a
        href={`${prefix}${locale === 'en' ? '/contact' : '/kontakt'}`}
        class="hidden rounded-full bg-navy px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-navy-700 sm:inline-flex"
      >
        {t.cta.primary}
      </a>
      <button
        type="button"
        id="mobile-menu-toggle"
        class="inline-flex items-center justify-center rounded-full p-2 text-navy lg:hidden"
        aria-label={t.common.menu}
        aria-expanded="false"
      >
        <Icon name="menu" class="h-6 w-6" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-navy-100 bg-white lg:hidden">
    <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-5 py-4" aria-label="Mobile">
      {links.map((l) => (
        <a href={l.href} class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink/80 hover:bg-navy-50">
          {l.label}
        </a>
      ))}
      <a
        href={`${prefix}${locale === 'en' ? '/contact' : '/kontakt'}`}
        class="mt-2 rounded-lg bg-navy px-3 py-2.5 text-center text-sm font-semibold text-white"
      >
        {t.cta.primary}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
