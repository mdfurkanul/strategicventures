---
import Icon from './Icon.astro';
import type { Locale } from '../data/site';

export interface Props { locale: Locale; }
const { locale } = Astro.props;

// 5 placeholder testimonials — realistic consulting client voices.
// Avatar colors rotate through brand palette.
const testimonials = [
  {
    quote: locale === 'sv'
      ? 'Strategic Ventures hjälpte oss att gå från forskningsresultat till kommersiell produkt på 18 månader. Deras förmåga att bygga broar mellan akademi och industri är unik.'
      : 'Strategic Ventures helped us go from research result to commercial product in 18 months. Their ability to bridge academia and industry is unique.',
    name: locale === 'sv' ? 'Dr. Anna Lindqvist' : 'Dr. Anna Lindqvist',
    role: locale === 'sv' ? 'VD, BioTech Solutions AB' : 'CEO, BioTech Solutions AB',
    initials: 'AL',
    color: 'navy' as const,
    sector: locale === 'sv' ? 'Life Science' : 'Life Science',
  },
  {
    quote: locale === 'sv'
      ? 'Vi fick inte bara en strategi — vi fick en partner som följde oss hela vägen till marknadslansering. Resultatet: 40% snabbare internationalisering än planerat.'
      : 'We didn\'t just get a strategy — we got a partner who stayed with us all the way to market launch. The result: 40% faster international expansion than planned.',
    name: locale === 'sv' ? 'Erik Sundberg' : 'Erik Sundberg',
    role: locale === 'sv' ? 'Grundare, Nordic Food Tech' : 'Founder, Nordic Food Tech',
    initials: 'ES',
    color: 'growth' as const,
    sector: locale === 'sv' ? 'Livsmedel' : 'Food & Beverage',
  },
  {
    quote: locale === 'sv'
      ? 'Deras ESG-strateg integrerades i vår affär på ett sätt som både stärkte varumärket och ökade lönsamheten. Ett strategiskt och praktiskt arbete av högsta klass.'
      : 'Their ESG strategy was integrated into our business in a way that strengthened our brand and improved profitability. Strategic and practical work of the highest class.',
    name: locale === 'sv' ? 'Maria Hernández' : 'Maria Hernández',
    role: locale === 'sv' ? 'CFO, Scandinavian Manufacturing Group' : 'CFO, Scandinavian Manufacturing Group',
    initials: 'MH',
    color: 'sky' as const,
    sector: locale === 'sv' ? 'Tillverkning' : 'Manufacturing',
  },
  {
    quote: locale === 'sv'
      ? 'Vi arbetade med Strategic Ventures för att strukturera vår finansieringsrunda. Deras nätverk bland investerare och forskningsinstitut öppnade dörrar vi inte visste fanns.'
      : 'We worked with Strategic Ventures to structure our funding round. Their network among investors and research institutes opened doors we didn\'t know existed.',
    name: locale === 'sv' ? 'Johan Karlsson' : 'Johan Karlsson',
    role: locale === 'sv' ? 'CEO, CleanTech Innovations' : 'CEO, CleanTech Innovations',
    initials: 'JK',
    color: 'navy' as const,
    sector: locale === 'sv' ? 'CleanTech' : 'CleanTech',
  },
  {
    quote: locale === 'sv'
      ? 'Ett exekutivt utbildningsprogram som faktiskt förändrade hur vi tänker kring innovation och hållbarhet. Engagerande, konkret och direkt tillämpbart i vår verksamhet.'
      : 'An executive education programme that genuinely changed how we think about innovation and sustainability. Engaging, concrete and directly applicable in our business.',
    name: locale === 'sv' ? 'Sara Andersson' : 'Sara Andersson',
    role: locale === 'sv' ? 'HR-direktör, Global Industries Ltd' : 'HR Director, Global Industries Ltd',
    initials: 'SA',
    color: 'growth' as const,
    sector: locale === 'sv' ? 'Utbildning' : 'Education',
  },
];

const accent = {
  navy:   { bg: 'bg-navy-50',   text: 'text-navy',   ring: 'ring-navy-200',   dot: 'bg-navy' },
  sky:    { bg: 'bg-sky-50',    text: 'text-sky-600',ring: 'ring-sky-200',    dot: 'bg-sky' },
  growth: { bg: 'bg-growth-50', text: 'text-growth-600', ring: 'ring-growth-200', dot: 'bg-growth' },
};

const prevLabel = locale === 'sv' ? 'Föregående' : 'Previous';
const nextLabel = locale === 'sv' ? 'Nästa' : 'Next';
const sectorLabel = locale === 'sv' ? 'Bransch' : 'Sector';
---
<div
  data-testimonial-slider
  data-autoplay="6000"
  class="relative"
>
  <!-- Slides track -->
  <div
    data-track
    class="flex snap-x snap-mandatory overflow-x-auto scroll-smooth scrollbar-none"
    style="scrollbar-width: none;"
  >
    {testimonials.map((t, i) => {
      const a = accent[t.color];
      return (
        <article
          data-slide
          data-index={i}
          class="w-full flex-shrink-0 snap-center px-1"
        >
          <div class="relative mx-auto max-w-3xl overflow-hidden rounded-3xl border border-navy-100 bg-white p-8 shadow-sm sm:p-12">
            <!-- brand top stripe -->
            <span class={`absolute inset-x-0 top-0 h-1 ${a.dot}`} aria-hidden="true"></span>

            <!-- decorative quote mark -->
            <span
              aria-hidden="true"
              class={`pointer-events-none absolute right-6 top-4 font-serif text-[120px] leading-none ${a.bg} ${a.text} opacity-20 sm:text-[160px]`}
            >
              &rdquo;
            </span>

            <div class="relative">
              <!-- stars -->
              <div class={`flex items-center gap-1 ${a.text}`} aria-label="5 of 5 stars">
                {[1,2,3,4,5].map(() => (
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2l2.9 6.3 6.9.7-5.2 4.6 1.5 6.8L12 17.8 5.9 20.4l1.5-6.8L2.2 9l6.9-.7L12 2z"/>
                  </svg>
                ))}
              </div>

              <!-- quote -->
              <blockquote class="mt-5">
                <p class="font-serif text-xl leading-relaxed text-navy sm:text-2xl sm:leading-relaxed">
                  &ldquo;{t.quote}&rdquo;
                </p>
              </blockquote>

              <!-- author -->
              <figcaption class="mt-7 flex items-center gap-4 border-t border-navy-100 pt-6">
                <span class={`flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full ${a.bg} ${a.text} font-serif text-sm font-bold ring-1 ${a.ring}`}>
                  {t.initials}
                </span>
                <div class="flex-1">
                  <p class="font-serif text-base font-semibold text-navy">{t.name}</p>
                  <p class="text-xs text-ink/60">{t.role}</p>
                </div>
                <span class={`hidden rounded-full px-3 py-1 text-[10px] font-semibold uppercase tracking-wider ${a.bg} ${a.text} ring-1 ${a.ring} sm:inline`}>
                  {t.sector}
                </span>
              </figcaption>
            </div>
          </div>
        </article>
      );
    })}
  </div>

  <!-- Controls -->
  <div class="mt-8 flex items-center justify-center gap-6">
    <!-- prev -->
    <button
      type="button"
      data-prev
      aria-label={prevLabel}
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-navy-200 bg-white text-navy transition hover:border-navy hover:bg-navy hover:text-white"
    >
      <Icon name="arrow-right" class="h-4 w-4 rotate-180" />
    </button>

    <!-- dots -->
    <div data-dots class="flex items-center gap-2">
      {testimonials.map((_, i) => (
        <button
          type="button"
          data-dot={i}
          aria-label={`${locale === 'sv' ? 'Gå till' : 'Go to'} ${i + 1}`}
          class="h-2 w-2 rounded-full bg-navy-200 transition-all duration-300 hover:bg-navy-300"
        ></button>
      ))}
    </div>

    <!-- next -->
    <button
      type="button"
      data-next
      aria-label={nextLabel}
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-navy-200 bg-white text-navy transition hover:border-navy hover:bg-navy hover:text-white"
    >
      <Icon name="arrow-right" class="h-4 w-4" />
    </button>
  </div>
</div>

<style>
  [data-testimonial-slider] [data-track] {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  [data-testimonial-slider] [data-track]::-webkit-scrollbar {
    display: none;
  }
  [data-testimonial-slider] [data-dot].is-active {
    width: 28px;
    border-radius: 9999px;
  }
</style>

<script>
  const slider = document.querySelector('[data-testimonial-slider]');
  if (slider) {
    const track = slider.querySelector('[data-track]');
    const slides = slider.querySelectorAll('[data-slide]');
    const dots = slider.querySelectorAll('[data-dot]');
    const prevBtn = slider.querySelector('[data-prev]');
    const nextBtn = slider.querySelector('[data-next]');
    const autoplayMs = Number(slider.getAttribute('data-autoplay') || '6000');

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function goTo(index: number) {
      current = (index + slides.length) % slides.length;
      const slide = slides[current] as HTMLElement;
      track?.scrollTo({ left: slide.offsetLeft - (track as HTMLElement).offsetLeft, behavior: 'smooth' });
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAuto() { stopAuto(); timer = setInterval(next, autoplayMs); }
    function stopAuto() { if (timer) { clearInterval(timer); timer = null; } }

    nextBtn?.addEventListener('click', () => { next(); startAuto(); });
    prevBtn?.addEventListener('click', () => { prev(); startAuto(); });
    dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); startAuto(); }));

    // Pause on hover
    slider.addEventListener('mouseenter', stopAuto);
    slider.addEventListener('mouseleave', startAuto);

    // Pause when tab is hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopAuto(); else startAuto();
    });

    // Update current index when user scrolls manually (swipe / drag)
    let scrollTimer: ReturnType<typeof setTimeout> | null = null;
    track?.addEventListener('scroll', () => {
      if (scrollTimer) clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => {
        const trackLeft = (track as HTMLElement).offsetLeft;
        let closest = 0;
        let minDist = Infinity;
        slides.forEach((s, i) => {
          const dist = Math.abs((s as HTMLElement).offsetLeft - trackLeft - (track as HTMLElement).scrollLeft);
          if (dist < minDist) { minDist = dist; closest = i; }
        });
        if (closest !== current) {
          current = closest;
          dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
        }
      }, 120);
    });

    // Respect reduced motion — no autoplay
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      startAuto();
    }

    // Init
    goTo(0);
  }
</script>
