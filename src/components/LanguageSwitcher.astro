---
import type { Locale } from '../data/site';
import { translatePath } from '../data/routes';

export interface Props {
  locale: Locale;
  path: string; // current page's path, in the CURRENT locale's slug (e.g. '/om-oss' or '/about')
}
const { locale, path } = Astro.props;
const otherLocale: Locale = locale === 'sv' ? 'en' : 'sv';

// Translate the current locale's path to the other locale's equivalent path
const otherLocalePath = translatePath(locale, path);

// Build the final href. English pages live under /en; Swedish at root.
const otherHref =
  otherLocale === 'en'
    ? otherLocalePath === '/' ? '/en' : `/en${otherLocalePath}`
    : otherLocalePath;

const label = otherLocale === 'en' ? 'English' : 'Svenska';
---
<a
  href={otherHref}
  class="inline-flex items-center gap-1.5 rounded-full border border-navy-200 px-3 py-1.5 text-xs font-semibold text-navy-700 transition hover:border-navy hover:bg-navy-50 hover:text-navy"
  aria-label={`Switch to ${label}`}
>
  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
    <circle cx="12" cy="12" r="9" />
    <path d="M3 12h18" />
    <path d="M12 3a14 14 0 0 0 0 18" />
    <path d="M12 3a14 14 0 0 1 0 18" />
  </svg>
  {label}
</a>
