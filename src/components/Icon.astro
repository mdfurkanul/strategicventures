---
// Lightweight inline SVG icon set. Usage: <Icon name="strategy" class="h-6 w-6" />
export interface Props {
  name:
    | 'strategy' | 'leaf' | 'lightbulb' | 'wheat' | 'handshake' | 'globe' | 'cap'
    | 'check' | 'arrow-right' | 'menu' | 'close' | 'mail' | 'phone' | 'linkedin'
    | 'map' | 'sparkles' | 'shield' | 'target';
