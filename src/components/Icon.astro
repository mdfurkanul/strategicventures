}
const { name, class: cls = 'h-6 w-6' } = Astro.props;
const stroke = 'stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" fill="none"';
---
{
  name === 'strategy' && (
    <svg class={cls} viewBox="0 0 24 24" {...{ stroke }}>
      <path d="M3 3v18h18" />
