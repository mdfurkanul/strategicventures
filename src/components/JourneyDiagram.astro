---
import Icon from './Icon.astro';
import type { Locale } from '../data/site';

export interface Props { locale: Locale; }
const { locale } = Astro.props;

// 7 services as waypoints on the journey from idea → impact
const waypoints = [
  {
    num: '01', icon: 'lightbulb' as const, color: 'growth' as const,
    phase: locale === 'sv' ? 'Idé' : 'Idea',
    name:  locale === 'sv' ? 'Innovation' : 'Innovation',
  },
  {
    num: '02', icon: 'strategy' as const, color: 'navy' as const,
    phase: locale === 'sv' ? 'Strategi' : 'Strategy',
    name:  locale === 'sv' ? 'Affärsutveckling' : 'Business Strategy',
  },
  {
    num: '03', icon: 'leaf' as const, color: 'growth' as const,
    phase: locale === 'sv' ? 'Hållbarhet' : 'Sustainability',
    name:  locale === 'sv' ? 'Hållbarhet & ESG' : 'Sustainability & ESG',
  },
  {
    num: '04', icon: 'wheat' as const, color: 'growth' as const,
    phase: locale === 'sv' ? 'Specialist' : 'Specialist',
    name:  locale === 'sv' ? 'Livsmedelsinnovation' : 'Food Innovation',
  },
  {
    num: '05', icon: 'handshake' as const, color: 'navy' as const,
    phase: locale === 'sv' ? 'Finansiering' : 'Funding',
    name:  locale === 'sv' ? 'Finansiering & partnerskap' : 'Funding & Partnerships',
  },
  {
    num: '06', icon: 'globe' as const, color: 'sky' as const,
    phase: locale === 'sv' ? 'Marknad' : 'Market',
    name:  locale === 'sv' ? 'Internationalisering' : 'International Expansion',
  },
  {
    num: '07', icon: 'cap' as const, color: 'navy' as const,
    phase: locale === 'sv' ? 'Kunskap' : 'Capability',
    name:  locale === 'sv' ? 'Utbildning' : 'Executive Education',
  },
];

const accent = {
  navy:   { dot: 'bg-navy',   text: 'text-navy',   ring: 'ring-navy-200',   stroke: '#2A3A8F' },
  sky:    { dot: 'bg-sky',    text: 'text-sky-600',ring: 'ring-sky-200',    stroke: '#34B5E5' },
  growth: { dot: 'bg-growth', text: 'text-growth-600', ring: 'ring-growth-200', stroke: '#6BBE44' },
};

const startLabel = locale === 'sv' ? 'Idé' : 'Idea';
const endLabel = locale === 'sv' ? 'Hållbar tillväxt' : 'Sustainable growth';
---
<div data-journey-diagram class="relative">
  <!-- Start label -->
  <div class="mb-6 flex items-center gap-3 pl-1">
    <span class="inline-flex h-2 w-2 rounded-full bg-navy-300"></span>
    <span class="font-mono text-[10px] font-medium uppercase tracking-[0.18em] text-ink/50">{locale === 'sv' ? 'Start · 7 steg' : 'Start · 7 steps'}</span>
  </div>

  <!-- Desktop: horizontal journey (md+), Mobile: vertical timeline -->
  <ol class="relative">
    <!-- horizontal connector line (desktop only) -->
    <span aria-hidden="true" class="pointer-events-none absolute left-0 right-0 top-7 hidden h-0.5 bg-gradient-to-r from-navy-200 via-sky-200 to-growth-300 md:block"></span>
    <!-- vertical connector line (mobile only) -->
    <span aria-hidden="true" class="pointer-events-none absolute left-[27px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-navy-200 via-sky-200 to-growth-300 md:hidden"></span>

    {waypoints.map((wp, i) => {
      const a = accent[wp.color];
      return (
        <li class="group relative flex md:inline-flex md:flex-col md:items-center md:w-[14%] md:align-top md:pb-0 pb-6 grid grid-cols-[56px_1fr] gap-4 md:gap-0 md:grid-cols-1">
          <!-- numbered node -->
          <div class={`relative z-10 flex h-14 w-14 items-center justify-center rounded-full border-2 bg-white font-serif text-lg font-semibold shadow-sm ring-4 ring-white transition duration-300 md:mb-4 ${
            wp.color === 'navy' ? 'border-navy text-navy' : wp.color === 'sky' ? 'border-sky text-sky-600' : 'border-growth text-growth-600'
          } group-hover:scale-110`}>
            {wp.num}
          </div>

          <div class="md:text-center">
            <span class={`inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${a.text} ${a.ring} ring-1`}>
              {wp.phase}
            </span>
            <p class="mt-2 font-serif text-sm font-semibold leading-tight text-navy md:text-[13px]">{wp.name}</p>
          </div>
        </li>
      );
    })}
  </ol>

  <!-- End marker -->
  <div class="mt-2 flex items-center gap-3 pl-1 md:mt-6 md:justify-end">
    <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-gradient-to-br from-navy via-sky to-growth text-white shadow-md">
      <Icon name="check" class="h-4 w-4" />
    </span>
    <span class="font-serif text-sm italic text-navy/70">{endLabel}</span>
  </div>
</div>
